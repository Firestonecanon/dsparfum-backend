# Variables d'environnement pour production Render

# Base de données
DATABASE_URL=file:./data/clients.db

# Serveur
NODE_ENV=production
PORT=3001

# CORS Origins (à personnaliser)
FRONTEND_URL=https://votre-frontend.onrender.com

# Stripe (optionnel - à configurer si vous voulez les webhooks)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Email (optionnel - pour notifications admin)
# ADMIN_EMAIL=votre@email.com
# ADMIN_EMAIL_PASSWORD=motdepasse_app
